---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { languages } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get base path from Astro.url
const url = new URL(Astro.url);
const base = import.meta.env.BASE_URL;

function getLocalizedPath(newLang: string) {
  const parts = url.pathname.split("/");
  // parts[0] is '', parts[1] is 'eternaltech'
  if (newLang === "en") {
    // Switch to EN: remove lang if it's there
    if (parts[2] === "id") {
      parts.splice(2, 1);
    }
  } else {
    // Switch to ID: add 'id' if not there
    if (parts[2] !== "id") {
      parts.splice(2, 0, "id");
    }
  }
  return parts.join("/") || "/";
}
---

<nav class="nav">
  <div class="container nav-container">
    <a href={base} class="logo">
      KYCAINE <span class="text-gold">ETERNALTECH</span>
    </a>

    <div class="nav-links">
      <a href="#services">{t("nav.services")}</a>
      <a href="#tech-stack">{t("nav.stack")}</a>
      <a href="#portfolio">{t("nav.work")}</a>
      <a href="#workflow">{t("nav.process")}</a>
      <a href="#contact" class="nav-cta">{t("nav.consultation")}</a>
      <!-- <button class="nav-cta" data-open-consultation>{t("nav.consultation")}</button> -->

      <div class="lang-switch">
        {
          Object.entries(languages).map(([code, label]) => (
            <a
              href={getLocalizedPath(code)}
              class:list={["lang-link", { active: lang === code }]}
            >
              {label}
            </a>
          ))
        }
      </div>
    </div>

    <button class="mobile-menu-toggle" aria-label="Toggle Menu" aria-expanded="false" aria-controls="nav-links">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.5rem 0;
    transition: all 0.4s ease;
    background-color: transparent;
  }

  .nav.scrolled {
    background-color: rgba(26, 18, 11, 0.95);
    padding: 1rem 0;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: 0.1em;
    z-index: 1100;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.8);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .nav-links a:hover {
    color: var(--color-gold);
  }

  .nav-cta {
    background-color: var(--color-gold);
    color: var(--color-dark-brown) !important;
    padding: 0.6rem 1.2rem;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background-color: var(--color-white) !important;
    transform: translateY(-2px);
  }

  .lang-switch {
    display: flex;
    gap: 0.5rem;
    margin-left: 1rem;
    padding-left: 1rem;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
  }

  .lang-link {
    font-size: 0.95rem !important;
    font-weight: 700;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .lang-link:hover,
  .lang-link.active {
    opacity: 1;
    color: var(--color-gold) !important;
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1100;
    width: 30px;
    height: 30px;
    padding: 0;
  }

  .mobile-menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-white);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  /* Hamburger Animation */
  .nav.menu-active .mobile-menu-toggle span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .nav.menu-active .mobile-menu-toggle span:nth-child(2) {
    opacity: 0;
    transform: translateX(10px);
  }

  .nav.menu-active .mobile-menu-toggle span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .text-gold {
    color: var(--color-gold);
  }

  @media (max-width: 992px) {
    .mobile-menu-toggle {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 100%;
      height: 100vh;
      background-color: rgba(26, 18, 11, 0.98);
      backdrop-filter: blur(15px);
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1050;
    }

    .nav.menu-active .nav-links {
      right: 0;
    }

    .nav-links a {
      font-size: 1.2rem;
    }

    .lang-switch {
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      margin-left: 0;
      padding-left: 0;
      padding-top: 1.5rem;
      margin-top: 0.5rem;
    }
  }
</style>

<script>
  // Navigation elements
  const nav = document.querySelector(".nav");
  const menuToggle = document.querySelector(".mobile-menu-toggle");
  const navLinks = document.querySelectorAll(".nav-links a");

  // Simple scroll effect for navigation
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add("scrolled");
    } else {
      nav?.classList.remove("scrolled");
    }
  });

  // Mobile menu toggle
  function toggleMenu() {
    const isExpanded = menuToggle?.getAttribute("aria-expanded") === "true";
    nav?.classList.toggle("menu-active");
    menuToggle?.setAttribute("aria-expanded", String(!isExpanded));
    document.body.style.overflow = isExpanded ? "" : "hidden";
  }

  menuToggle?.addEventListener("click", toggleMenu);

  // Close menu when clicking a link
  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (nav?.classList.contains("menu-active")) {
        toggleMenu();
      }
    });
  });

  // Handle window resize
  window.addEventListener("resize", () => {
    if (window.innerWidth > 992 && nav?.classList.contains("menu-active")) {
      toggleMenu();
    }
  });
</script>
